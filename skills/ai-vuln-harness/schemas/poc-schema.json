{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://opencode.ai/schemas/poc/v1",
  "title": "Proof-of-Confirmation Schema",
  "description": "A reproducible PoC that attempts to confirm or disprove a vulnerability finding. Each PoC documents the finding under test, the test harness, input vectors, observed results, and any reproduction steps.",
  "type": "object",
  "required": [
    "schema_version",
    "poc_id",
    "finding",
    "harness",
    "test_cases",
    "result"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of this PoC schema",
      "enum": ["v1"]
    },
    "poc_id": {
      "type": "string",
      "description": "Unique identifier for this PoC (e.g., finding ID or hash)",
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "finding": {
      "type": "object",
      "description": "The vulnerability finding being tested",
      "required": ["snippet_id", "class", "severity", "desc", "call_path"],
      "properties": {
        "snippet_id": {
          "type": "string",
          "description": "Snippet identifier from the snippet DB"
        },
        "class": {
          "type": "string",
          "description": "Vulnerability class (e.g., buffer-overflow, format-string)"
        },
        "severity": {
          "type": "string",
          "enum": ["INFORMATIONAL", "LOW", "MEDIUM", "HIGH", "CRITICAL"]
        },
        "desc": {
          "type": "string",
          "description": "Human-readable description of the alleged vulnerability"
        },
        "call_path": {
          "type": "array",
          "description": "Call path from entry point to vulnerable sink",
          "items": {"type": "string"}
        }
      }
    },
    "harness": {
      "type": "object",
      "description": "The test harness used to reproduce the finding",
      "required": ["language", "compiler", "sanitizer", "source_file"],
      "properties": {
        "language": {
          "type": "string",
          "description": "Programming language of the test harness"
        },
        "compiler": {
          "type": "object",
          "description": "Compiler used to build the harness",
          "required": ["name", "version", "flags"],
          "properties": {
            "name": {"type": "string"},
            "version": {"type": "string"},
            "flags": {
              "type": "array",
              "description": "Compiler flags (e.g., -fsanitize=address, -O0)",
              "items": {"type": "string"}
            }
          }
        },
        "sanitizer": {
          "type": "string",
          "description": "Sanitizer used to detect the vulnerability class (e.g., AddressSanitizer, UndefinedBehaviorSanitizer)"
        },
        "source_file": {
          "type": "string",
          "description": "Path to the PoC source file"
        },
        "dependencies": {
          "type": "array",
          "description": "External dependencies required to build and run",
          "items": {"type": "string"}
        },
        "libraries": {
          "type": "array",
          "description": "Linker libraries (e.g., -lz, -lssl)",
          "items": {"type": "string"}
        }
      }
    },
    "test_cases": {
      "type": "array",
      "description": "Individual test cases that exercise the vulnerable code path",
      "items": {
        "type": "object",
        "required": ["id", "description", "input", "expected"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Test case identifier"
          },
          "description": {
            "type": "string",
            "description": "What this test case exercises"
          },
          "input": {
            "type": "object",
            "description": "Input vector or parameters",
            "required": ["payload_size", "window_bits"],
            "properties": {
              "payload_size": {
                "type": "integer",
                "description": "Size of the decompressed payload in bytes"
              },
              "window_bits": {
                "type": "integer",
                "description": "Window bits parameter passed to inflateInit2 (8-15, or -8 to -15)"
              },
              "payload_pattern": {
                "type": "string",
                "description": "Description of the payload pattern (e.g., 'repeating X', 'counter 0..255')"
              },
              "iterations": {
                "type": "integer",
                "description": "Number of times to run the test (default: 1)"
              }
            }
          },
          "expected": {
            "type": "object",
            "description": "Expected behavior if the vulnerability is absent (null hypothesis)",
            "required": ["crash", "asan_errors", "output_nonempty"],
            "properties": {
              "crash": {
                "type": "boolean",
                "description": "Does the finding claim the program will crash?"
              },
              "asan_errors": {
                "type": "integer",
                "description": "Expected number of ASan errors (0 = safe)"
              },
              "output_nonempty": {
                "type": "boolean",
                "description": "Is output expected?"
              }
            }
          },
          "actual": {
            "type": "object",
            "description": "Actual observed behavior (populated after execution)",
            "properties": {
              "exit_code": {
                "type": "integer"
              },
              "asan_error_count": {
                "type": "integer",
                "description": "Number of AddressSanitizer errors observed"
              },
              "asan_error_types": {
                "type": "array",
                "description": "Types of ASan errors observed (e.g., heap-buffer-overflow)",
                "items": {"type": "string"}
              },
              "output_bytes": {
                "type": "integer",
                "description": "Bytes of output produced"
              },
              "decompressed_match": {
                "type": "boolean",
                "description": "Did the decompressed output match the original input?"
              },
              "stderr": {
                "type": "string",
                "description": "Stderr output from the run"
              }
            }
          }
        }
      }
    },
    "result": {
      "type": "object",
      "description": "Overall result of the PoC",
      "required": ["status", "verdict", "reasoning"],
      "properties": {
        "status": {
          "type": "string",
          "description": "Was the PoC successfully built and executed?",
          "enum": ["completed", "build_failed", "execution_failed", "incomplete"]
        },
        "verdict": {
          "type": "string",
          "description": "Does the finding reproduce?",
          "enum": ["confirmed", "rejected", "needs-more-info"]
        },
        "reasoning": {
          "type": "string",
          "description": "Explanation of the verdict"
        },
        "vulnerable_code_paths": {
          "type": "array",
          "description": "Specific code paths where the vulnerability was confirmed (empty if rejected)",
          "items": {
            "type": "object",
            "properties": {
              "function": {"type": "string"},
              "line": {"type": "integer"},
              "condition": {"type": "string"}
            }
          }
        },
        "reproducibility_notes": {
          "type": "string",
          "description": "Any notes about reproducing this result on different systems"
        }
      }
    }
  }
}
